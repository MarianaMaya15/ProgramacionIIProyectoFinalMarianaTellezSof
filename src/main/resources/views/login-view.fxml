<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16.0" styleClass="section-wrapper" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.eventos.controller.LoginController">
    <children>
        <Label styleClass="section-title" text="EVENTOS UQ" />
        <Label styleClass="section-subtitle" text="Inicia sesion para continuar" />
        <VBox spacing="10.0" maxWidth="360.0">
            <children>
                <Label text="Correo" />
                <TextField fx:id="correoField" promptText="correo@eventosuq.com" />
                <Label text="Contrasena" />
                <PasswordField fx:id="contrasenaField" promptText="Contrasena" />
            </children>
        </VBox>
        <HBox spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#iniciarSesion" styleClass="primary-button" text="Iniciar sesion" />
                <Button mnemonicParsing="false" onAction="#irRegistro" styleClass="secondary-button" text="Registrarse" />
            </children>
        </HBox>
        <Label styleClass="detail-text" text="Admin: admin@eventosuq.com / admin123  |  Usuario: mariana@eventosuq.com / 1234" />
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>

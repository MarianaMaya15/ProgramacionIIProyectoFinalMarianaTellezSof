<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" styleClass="section-wrapper" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.eventos.controller.PerfilController">
    <children>
        <Label styleClass="section-title" text="Mi perfil" />
        <Label styleClass="section-subtitle" text="Actualiza tus datos basicos de usuario." />
        <VBox spacing="10.0" styleClass="detail-panel">
            <children>
                <Label text="Nombre completo" />
                <TextField fx:id="nombreField" promptText="Nombre" />
                <Label text="Correo" />
                <TextField fx:id="correoField" promptText="Correo" />
                <Label text="Telefono" />
                <TextField fx:id="telefonoField" promptText="Telefono" />
            </children>
            <padding>
                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </padding>
        </VBox>
        <HBox spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#guardarPerfil" styleClass="primary-button" text="Guardar cambios" />
                <Button mnemonicParsing="false" onAction="#volverCartelera" styleClass="secondary-button" text="Volver" />
            </children>
        </HBox>
    </children>
</VBox>
